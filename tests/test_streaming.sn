# ==============================================================================
# tests/test_streaming.sn — Streaming response tests
# ==============================================================================
# Spins up a real HTTP server that streams responses, then connects with a
# raw TCP client to verify the chunked-transfer framing and end-to-end
# byte equality.
# ==============================================================================

import "../src/server"
import "sindarin-pkg-sdk/src/net/tcp"
import "sindarin-pkg-threads/src/shutdown_signal"

# Producer state for /stream — yields three text chunks then EOF.
sync var streamIdx: int = 0

fn streamProducer(): str =>
  if streamIdx == 0 =>
    streamIdx = 1
    return "alpha "
  if streamIdx == 1 =>
    streamIdx = 2
    return "beta "
  if streamIdx == 2 =>
    streamIdx = 3
    return "gamma"
  return ""

fn streamHandler(req: HttpRequest): HttpResponse =>
  streamIdx = 0
  return HttpResponse.stream(streamProducer)

# Producer state for /events — yields two SSE frames.
sync var sseIdx: int = 0

fn sseProducer(): str =>
  if sseIdx == 0 =>
    sseIdx = 1
    return "data: first\n\n"
  if sseIdx == 1 =>
    sseIdx = 2
    return "data: second\n\n"
  return ""

fn sseHandler(req: HttpRequest): HttpResponse =>
  sseIdx = 0
  return HttpResponse.sse(sseProducer)

# Decode a chunked-transfer body. Input is the bytes after \r\n\r\n.
# Returns the concatenated chunk payloads.
fn decodeChunked(body: str): str =>
  var out: str = ""
  var rest: str = body
  while rest.length > 0 =>
    var lineEnd: int = rest.indexOf("\r\n")
    if lineEnd < 0 =>
      break
    var sizeHex: str = rest.substring(0, lineEnd)
    var size: int = hexToInt(sizeHex)
    rest = rest.substring(lineEnd + 2, rest.length)
    if size == 0 =>
      break
    out = out + rest.substring(0, size)
    # Skip chunk data + trailing \r\n
    rest = rest.substring(size + 2, rest.length)
  return out

fn hexToInt(s: str): int =>
  var result: int = 0
  for var i: int = 0; i < s.length; i++ =>
    var c: char = s.charAt(i)
    var v: int = 0
    var ci: int = c.toInt()
    if ci >= 48 && ci <= 57 => # '0'..'9'
      v = ci - 48
    else if ci >= 97 && ci <= 102 => # 'a'..'f'
      v = ci - 97 + 10
    else if ci >= 65 && ci <= 70 => # 'A'..'F'
      v = ci - 65 + 10
    result = result * 16 + v
  return result

fn runRequest(port: int, path: str): str =>
  var conn: TcpStream = TcpStream.connect($"127.0.0.1:{port}")
  conn.writeLine($"GET {path} HTTP/1.1")
  conn.writeLine("Host: localhost")
  conn.writeLine("Connection: close")
  conn.writeLine("")
  var bytes: byte[] = conn.readAll()
  conn.dispose()
  return bytes.toString()

sync var testsPassed: int = 0
sync var testsFailed: int = 0

fn check(condition: bool, message: str): void =>
  if !condition =>
    print($"  FAIL: {message}\n")
    testsFailed++
  else =>
    testsPassed++

fn runStreamingTests(sig: ShutdownSignal, port: int): void =>
  # Test 1: chunked download yields the expected body
  var resp: str = runRequest(port, "/stream")
  check(resp.contains("Transfer-Encoding: chunked"), "Should advertise chunked encoding")
  check(!resp.contains("Content-Length:"), "Should NOT include Content-Length on streaming response")
  var sepIdx: int = resp.indexOf("\r\n\r\n")
  check(sepIdx > 0, "Response must have header/body separator")
  var body: str = resp.substring(sepIdx + 4, resp.length)
  var decoded: str = decodeChunked(body)
  check(decoded == "alpha beta gamma", $"Decoded body should equal 'alpha beta gamma', got '{decoded}'")

  # Test 2: SSE response sets text/event-stream and frames cleanly
  var sse: str = runRequest(port, "/events")
  check(sse.contains("Content-Type: text/event-stream"), "SSE must set text/event-stream")
  check(sse.contains("Cache-Control: no-cache"), "SSE must set Cache-Control: no-cache")
  var sseSep: int = sse.indexOf("\r\n\r\n")
  var sseBody: str = sse.substring(sseSep + 4, sse.length)
  var sseDecoded: str = decodeChunked(sseBody)
  check(sseDecoded.contains("data: first"), "SSE should contain first frame")
  check(sseDecoded.contains("data: second"), "SSE should contain second frame")

  print($"\nTests passed: {testsPassed}, failed: {testsFailed}\n")
  sig.signal()

fn main(): void =>
  var router: Router = Router.new()
  router.get("/stream", streamHandler)
  router.get("/events", sseHandler)

  var sig: ShutdownSignal = ShutdownSignal.new()
  var listener: TcpListener = TcpListener.bind(":0")
  var port: int = listener.port()
  var server: HttpServer<TcpStream> = HttpServer < TcpStream >.new(router)

  & runStreamingTests(sig, port)

  var acceptFn: fn(): TcpStream = fn(): TcpStream => listener.acceptOrShutdown(sig.fd())
  server.serve(acceptFn, port)

  listener.dispose()
  sig.dispose()

  if testsFailed != 0 =>
    print("Some streaming tests failed!\n")
    exit(1)
  print("All streaming tests passed!\n")
